# ── Required for the default (Fireworks) provider ───────────────────────
# Generate at https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=fw_your_key_here

# ── Optional overrides ──────────────────────────────────────────────────
# PROVIDER=ollama                                     # switch to local Ollama
# MODEL=accounts/<account>/deployments/<id>           # different Fireworks deployment
# MODEL=qwen3-vl:8b-instruct                          # different Ollama model
# OLLAMA_URL=http://localhost:11434/api/chat          # custom Ollama endpoint
